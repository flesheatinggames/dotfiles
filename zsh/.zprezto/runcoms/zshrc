# Nvim Dev Tmux
devenv() {
  local start_dir="${1:-$PWD}"
  local session_name="main-$(date +%s)"
  osascript -e 'tell application "iTerm2" to tell current window to set zoomed to true'
  tmux new-session -d -s "$session_name" -x "$(tput cols)" -y "$(tput lines)" -c "$start_dir"
  tmux split-window -h -p 30 -c "$start_dir"
  tmux split-window -v -p 25 -c "$start_dir"
  tmux select-pane -t 0
  tmux send-keys -t "$session_name:1.0" 'nvim .' Enter
  tmux send-keys -t "$session_name:1.1" 'ccd' Enter
  tmux attach-session -t "$session_name"
}

