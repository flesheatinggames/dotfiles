alias unity-version='$UNITY_PATH -version'

# Unity compilation checking function
unity-compile() {
    local project_path="${1:-$(pwd)}"
    echo "Checking compilation for project: $project_path"
    $UNITY_PATH -batchmode -quit -projectPath "$project_path" -logFile - 2>&1 | grep -E "(error|Error|ERROR|CompilerError|compilation failed)"
    local exit_code=$?
    if [ $exit_code -eq 1 ]; then
        echo "✅ No compilation errors found"
        return 0
    else
        echo "❌ Compilation errors detected"
        return 1
    fi
}

# Unity test runner function
unity-test() {
    local project_path="${1:-$(pwd)}"
    local test_mode="${2:-EditMode}"
    echo "Running Unity tests in $test_mode for project: $project_path"
    $UNITY_PATH -batchmode -quit -projectPath "$project_path" -runTests -testPlatform "$test_mode" -logFile -
}

# Unity build function (works with current directory)
unity-build() {
    local build_target="${1:-Android}"
    local project_path="${2:-$(pwd)}"
    echo "Building Unity project for $build_target platform at: $project_path"
    $UNITY_PATH -batchmode -quit -projectPath "$project_path" -buildTarget "$build_target" -logFile -
}

